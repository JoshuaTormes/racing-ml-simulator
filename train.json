{
  "population": 1000,
  "generations": 1500,
  "threads": 8,
  "seed": 42,
  "headless": true,
  "out": "out_v2",
  "log_csv": true,

  "train_maps": [
    "maps/map1_chicanes_infernais.json",
    "maps/map4_obstaculos.json",
    "maps/map5_tecnico_avancado.json"
  ],
  "val_maps": ["maps/map7_pesadelo.json"],
  "test_maps": ["maps/map8_caos_total.json"],

  "fitness_agg": "cvar-rank",
  "cvar_alpha": 1.0,
  "curriculum": "none",

  "augment": ["mirror", "reverse"],
  "procedural_train": 4,
  "proc_width_min": 60,
  "proc_width_max": 80,

  "random_spawn": true,
  "episodes_per_eval": 2,

  "select_by_val": true,
  "val_select_topk": 10
}
